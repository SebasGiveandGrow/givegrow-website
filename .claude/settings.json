{
  "permissions": {
    "allow": [
      "Bash(node scripts/validate.mjs)",
      "Bash(node --check:*)",
      "Bash(md5sum:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(npx wrangler dev:*)",
      "Bash(python3 -m http.server:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git rebase:*)",
      "Read(./.ghtoken)",
      "Read(**/.env*)"
    ]
  }
}
