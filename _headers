/*
  Cache-Control: no-cache, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.basemaps.cartocdn.com; connect-src 'self' https://givegrow-alma.sebas-4af.workers.dev https://cloudflareinsights.com https://script.google.com https://script.googleusercontent.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests

/*.html
  Cache-Control: no-store, must-revalidate

/*.json
  Cache-Control: no-store, must-revalidate

/sitemap.xml
  Cache-Control: max-age=86400

/img/*
  Cache-Control: public, max-age=604800

/vendor/*
  Cache-Control: public, max-age=2592000

/docs/*
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=2592000
